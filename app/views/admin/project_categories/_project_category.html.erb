<div class="flex gap-4 items-center justify-between bg-white p-4 border">
  <%= inline_svg project_category.icon_path, class: "w-10 h-10 shrink-0" %>
  <div class="flex flex-col gap-4 grow">
    <h2 class="text-xl font-bold"><%= project_category.name %></h2>
    <p class="text-gray-500"><%= project_category.description %></p>
  </div>
  <div class="flex gap-4">
    <%= render "admin/shared/change_position_buttons", record: project_category %>
    <%= link_to t("edit"), edit_admin_project_category_path(project_category), class: "admin-btn-secondary" %>
  </div>
</div>