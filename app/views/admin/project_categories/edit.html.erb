<div class="flex justify-between items-center mb-6">
  <div class="flex gap-4 items-center mb-4">
    <%= inline_svg @project_category.icon_path, class: "w-10 h-10 shrink-0" %>
    <h1 class="text-2xl font-bold">
      <%= t("edit") %> <span id="<%= dom_id(@project_category, :name) %>">"<%= @project_category.name %>"</span>
    </h1>
  </div>
</div>
<%= form_with model: [:admin, @project_category], class: "flex flex-col gap-4" do |form| %>
  <div class="flex gap-3">
    <div class="w-full">
      <%= form.label :name, "#{t("name")} FR" %>
      <%=
        form.text_field :name,
        placeholder: "#{t("name")} FR*",
        required: true,
        class: "w-full border p-3 font-bold text-xl"
      %>
    </div>
    <div class="w-full">
      <%= form.label :name_en, "#{t("name")} EN" %>
      <%=
        form.text_field :name_en,
        placeholder: "#{t("name")} EN",
        class: "w-full border p-3 font-bold text-xl"
      %>
    </div>
  </div>
  <div class="flex gap-3">
    <div class="w-full">
      <%= form.label :description, "#{t("description")} FR" %>
      <%=
        form.textarea :description,
        placeholder: "#{t("description")} FR",
        class: "w-full border p-3"
      %>
    </div>
    <div class="w-full">
      <%= form.label :description_en, "#{t("description")} EN" %>
      <%=
        form.textarea :description_en,
        placeholder: "#{t("description")} EN",
        class: "w-full border p-3"
      %>
    </div>
  </div>

  <%= form.label :long_description, "#{t('long_description')} EN" %>
  <div>
    <%= form.rich_textarea :long_description %>
  </div>

  <%= form.submit t("save"), class: "admin-btn-primary cursor-pointer" %>
<% end %>
