<header class="my-10 flex flex-col gap-5">
  <h1 class="text-5xl font-bold border-b border-black"><%= t("partners") %></h1>
</header>

<section class="mt-3 flex flex-col gap-10">
  <%= render_translated_action_text(@partners_text, :text) %>
  <% @partner_categories.each do |partner_category| %>
    <div class="flex flex-col gap-4">
      <h2 class="text-3xl font-bold flex gap-3 items-center">
        <%= inline_svg partner_category.icon_path, class: "w-10 h-10 shrink-0" %>
        <span><%= translates(partner_category, :name) %></span>
      </h2>
      <% if partner_category.description? %>
        <p><%= translates(partner_category, :description) %></p>
      <% end %>
      <div class="mt-4 flex gap-6 justify-evenly flex-wrap">
        <% partner_category.partners.each do |partner| %>
          <div class="flex flex-col gap-3 items-center shadow-border p-4 w-60">
            <% if partner.logo.attached? %>
              <div class="w-full h-32 flex items-center justify-center">
                <%= image_tag partner.logo.variant(:default) %>
              </div>
            <% end %>
            <p class="text-xl font-bold text-center"><%= partner.name %></p>
            <p class="grow"><%= translates(partner, :description) %></p>
            <% if partner.website_url.present? %>
              <%= link_to t("website"), partner.website_url, target: :_blank, class: "btn-old-school self-end" %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</section>